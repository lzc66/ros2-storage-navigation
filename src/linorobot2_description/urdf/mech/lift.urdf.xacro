<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro name="lift_mechanism" params="base_length">
    <!-- Prismatic lift joint: vertical (Z-axis), range 0.0 ~ 0.8m -->
    <joint name="lift_joint" type="prismatic">
      <parent link="base_link"/>
      <child link="lift_link"/>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit effort="100" lower="0.0" upper="0.8" velocity="0.2"/>
      <dynamics damping="10.0" friction="5.0"/>
    </joint>

    <!-- Lift platform (payload carrier) -->
    <link name="lift_link">
      <visual>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length * 0.6} ${base_length * 0.4} 0.02"/>
        </geometry>
        <material name="gray">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length * 0.6} ${base_length * 0.4} 0.02"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <!-- Non-zero mass and inertia — anti-explosion constraint -->
        <mass value="2.0"/>
        <inertia
          ixx="0.02" ixy="0.0" ixz="0.0"
          iyy="0.02" iyz="0.0"
          izz="0.01"/>
      </inertial>
    </link>

    <gazebo reference="lift_link">
      <visual>
        <material>
          <ambient>0.6 0.6 0.6 1.0</ambient>
          <diffuse>0.6 0.6 0.6 1.0</diffuse>
          <specular>0.1 0.1 0.1 1.0</specular>
        </material>
      </visual>
    </gazebo>
  </xacro:macro>
</robot>
