<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro name="classic_drive_plugin" params="">
    <!-- Planar Move plugin: applies omnidirectional force to base_link,
         ideal for mecanum chassis without per-wheel binding.
         Subscribes /cmd_vel, publishes /odom + /tf. -->
    <gazebo>
      <plugin filename="libgazebo_ros_planar_move.so"
              name="mecanum_planar_move">
        <ros>
          <remapping>cmd_vel:=cmd_vel</remapping>
          <remapping>odom:=odom</remapping>
        </ros>
        <update_rate>50.0</update_rate>
        <publish_rate>50.0</publish_rate>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_footprint</robot_base_frame>
        <covariance_x>0.0001</covariance_x>
        <covariance_y>0.0001</covariance_y>
        <covariance_yaw>0.01</covariance_yaw>
      </plugin>
    </gazebo>

    <!-- Joint state publisher: exposes wheel + lift joints for TF tree -->
    <gazebo>
      <plugin filename="libgazebo_ros_joint_state_publisher.so"
              name="joint_state_publisher">
        <ros>
        </ros>
        <update_rate>50.0</update_rate>
        <joint_name>front_left_wheel_joint</joint_name>
        <joint_name>front_right_wheel_joint</joint_name>
        <joint_name>rear_left_wheel_joint</joint_name>
        <joint_name>rear_right_wheel_joint</joint_name>
        <joint_name>lift_joint</joint_name>
      </plugin>
    </gazebo>
  </xacro:macro>
</robot>
